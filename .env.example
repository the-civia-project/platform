# Postgres (fake-eidas; optional for API if DATABASE_URL is wired later)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
# If you omit the database name (…:5432 only), the API appends /postgres automatically.

# Clerk — https://dashboard.clerk.com/~/api-keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Platform API (apps/ui reads via app.config extra)
PLATFORM_API_URL=http://platform.localhost:3001

# MinIO (API only — avatars are served via GET /media/avatars/… on the platform API)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=avatars
# Bucket is created by `docker compose up` (minio-init). Existing stacks: `docker compose run --rm minio-init`

# Optional: Clerk webhooks (not required for MVP)
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_
