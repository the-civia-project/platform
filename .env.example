# Postgres (fake-eidas; optional for API if DATABASE_URL is wired later)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
# If you omit the database name (…:5432 only), the API appends /postgres automatically.

# Clerk — https://dashboard.clerk.com/~/api-keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Platform API (apps/ui reads via app.config extra)
PLATFORM_API_URL=http://platform.localhost:3001

# S3-compatible object storage (API only — avatars are served via GET /media/avatars/…)
# Auth: one object-storage *user* with an access key and a secret key (SigV4; no STS session token).
# Local: docker compose MinIO — same URL for all three endpoints; root user keys below.
# Prod (UpCloud): distinct S3 / IAM / STS URLs from the control panel; create a user and download keys.
S3_ENDPOINT=http://localhost:9000
S3_IAM_ENDPOINT=http://localhost:9000
S3_STS_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_AVATAR_BUCKET=avatars
# Bucket is created by `docker compose up` (minio-init). Existing stacks: `docker compose run --rm minio-init`

# EUID (Sandbox)
EXPO_PUBLIC_EUDI_VERIFIER_URL=https://platform.theciviaproject.org
# Public base URL for wallet presentation redirect_uri (defaults to EXPO_PUBLIC_EUDI_VERIFIER_URL)
EUDI_VERIFIER_PUBLIC_URL=https://platform.theciviaproject.org
EUDI_VERIFIER_API_SECRET=dev-only-long-random-string
EUDI_ACCESS_CERT_PATH=./path/to/access.pem
EUDI_ACCESS_CERT_KEY_PATH=./path/to/access-key.pem
EUDI_REGISTRATION_CERT_PATH=./path/to/registration.jwt
# Local dev without sandbox certs: generate ephemeral signing material (not for production)
# EUDI_DEV_INSECURE_SIGNING=1

EUDI_X509_HASH_CLIENT_ID=base64-encoded-hash
# apps/ui — bare hash or full x509_hash:… client id for EUDIQRCode
EXPO_PUBLIC_EUDI_X509_HASH_CLIENT_ID=base64-encoded-hash