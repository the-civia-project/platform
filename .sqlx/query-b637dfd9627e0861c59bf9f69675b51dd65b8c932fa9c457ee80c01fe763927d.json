{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                u.id,\n                u.validation_type as \"validation_type: ValidationType\",\n                u.citizen_of as \"citizenof: Vec<CountryNumericCode>\",\n                u.handle,\n                u.tag as \"tag: AccountTag\",\n                u.name,\n                u.avatar,\n                u.location,\n                u.created_at,\n                u.updated_at\n            FROM account.\"user\" u\n            INNER JOIN account.clerk_validation cv ON cv.id = u.id\n            WHERE cv.clerk_id = $1\n            ",
